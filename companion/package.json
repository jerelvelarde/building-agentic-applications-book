{
  "name": "agentic-applications-2026-companion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p apps/ledger-web/tsconfig.json",
    "test": "vitest run",
    "build:lib": "tsc -p tsconfig.build.json",
    "build": "npm run build:lib",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.57",
    "@ag-ui/core": "0.0.57",
    "@copilotkit/channels": "0.1.1",
    "@copilotkit/channels-slack": "0.1.2",
    "@copilotkit/channels-ui": "0.1.1",
    "@copilotkit/react-core": "1.62.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "rxjs": "7.8.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "22.19.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "prettier": "3.8.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vite": "8.1.4",
    "vitest": "4.1.3"
  }
}
